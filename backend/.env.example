# Environment
PORT=4000
STELLAR_NETWORK=testnet
HORIZON_URL=https://horizon-testnet.stellar.org
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Database
DATABASE_URL=postgresql://remituser:remitpass@localhost:5432/remitmortgage

# CORS Configuration (comma-separated list of allowed origins)
# Default: http://localhost:3000,http://localhost:4000 for local development
# Production example: https://app.remitmortgage.com,https://www.remitmortgage.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4000

# Contract IDs (fill in after deployment)
ESCROW_CONTRACT_ID=
LENDING_POOL_CONTRACT_ID=
USDC_TOKEN_ID=

# Pinata IPFS integration keys
PINATA_API_KEY=
PINATA_SECRET_API_KEY=
# Email SMTP configuration
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@remitmortgage.com

# Webhook secret for payload signing (HMAC SHA-256)
WEBHOOK_SECRET=your_super_secret_webhook_signing_key_here

